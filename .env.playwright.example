# Copy to .env.playwright.local (gitignored) and fill secrets before running:
#   cp .env.playwright.example .env.playwright.local
#
# Run preview smoke suite:
#   pnpm test:smoke:preview

# Web app under test (disables local webServer when set)
PLAYWRIGHT_BASE_URL=https://adnexus-ai.apps.softblaze.net

# API base for direct health checks (no trailing slash)
PLAYWRIGHT_API_URL=https://adnexus-api.apps.softblaze.net

# Option A — form sign-in (runs full auth-flow + dashboard specs)
# PLAYWRIGHT_TEST_EMAIL=
# PLAYWRIGHT_TEST_PASSWORD=

# Option B — pre-issued JWT (skips form sign-in; still runs dashboard + token session tests)
# SMOKE_AUTH_TOKEN=
