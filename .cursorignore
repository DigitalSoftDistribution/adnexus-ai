# /<repo>/.cursorignore — same indexer-ignore rules as /home/devops/.cursorignore
# but scoped to a single repo (no sibling-worktree patterns).

# === Build outputs ===
node_modules/
.next/
.turbo/
dist/
build/
out/
.parcel-cache/
.swc/
coverage/
.nyc_output/
storybook-static/

# === Language caches ===
.venv/
__pycache__/
*.pyc
.mypy_cache/
.pytest_cache/
target/                  # Rust
.gradle/                 # Java
vendor/                  # PHP/Go

# === Package manager ===
.pnpm-store/
.npm/
.yarn/

# === IDE / Editor ===
.vscode/.bak*
.cursor/.bak*
.cursor/plugins/cache/
.idea/

# === Test / E2E artifacts ===
test-results/
playwright-report/
.playwright/
e2e-results/

# === Generated / lockfile-noise ===
pnpm-lock.yaml
package-lock.json
yarn.lock
*.tsbuildinfo

# === Large data dirs (project-specific — add yours here) ===
storage/framework/
public/uploads/
.supabase/
.firebase/

# === Logs ===
*.log
logs/
var/cache/
var/log/
