# ═══════════════════════════════════════════════════════════════════════════════
# AdNexus Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and update values for your local environment.
# Never commit `.env` files to version control!
#
# Quick Start:
#   cp .env.example .env
#   make setup
#   make dev
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 🔧 CORE APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

# Application environment: development | staging | production
NODE_ENV=development

# Application name (used in logs, error messages, etc.)
APP_NAME=adnexus-backend

# API Server port (host)
API_PORT=3001

# MCP Server port (host)
MCP_PORT=3002

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ─────────────────────────────────────────────────────────────────────────────
# 🗄️ DATABASE — PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Docker service name used internally)
DATABASE_URL=postgresql://adnexus:devpassword123@postgres:5432/adnexus?schema=public

# Individual connection components (used by docker-compose)
POSTGRES_DB=adnexus
POSTGRES_USER=adnexus
POSTGRES_PASSWORD=devpassword123
POSTGRES_PORT=5432
POSTGRES_LOG_LEVEL=all        # none, ddl, mod, all

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# ─────────────────────────────────────────────────────────────────────────────
# 🔴 REDIS
# ─────────────────────────────────────────────────────────────────────────────

# Redis connection URL
REDIS_URL=redis://redis:6379

# Redis host port (for host connections)
REDIS_PORT=6379

# Redis database index (0-15)
REDIS_DB=0

# Redis key prefix (for multi-tenant isolation)
REDIS_PREFIX=adnexus:

# Session TTL in seconds (24 hours)
SESSION_TTL=86400

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 AUTHENTICATION & SECURITY
# ─────────────────────────────────────────────────────────────────────────────

# JWT secret — CHANGE THIS IN PRODUCTION!
# Generate: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-me-in-production

# JWT token expiration
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Argon2 password hashing
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4
ARGON2_SALT_LENGTH=32
ARGON2_HASH_LENGTH=64

# API rate limiting
RATE_LIMIT_WINDOW_MS=900000        # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5              # Stricter limit for auth endpoints

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 MCP SERVER (Model Context Protocol)
# ─────────────────────────────────────────────────────────────────────────────

# MCP transport: stdio | sse | http
MCP_TRANSPORT=sse

# MCP allowed origins (CORS)
MCP_ALLOWED_ORIGINS=*

# Max tokens per MCP request
MCP_MAX_TOKENS=4096

# MCP request timeout (ms)
MCP_TIMEOUT_MS=30000

# MCP tools directory path
MCP_TOOLS_PATH=./src/mcp/tools

# ─────────────────────────────────────────────────────────────────────────────
# 📧 EMAIL (SMTP / SendGrid)
# ─────────────────────────────────────────────────────────────────────────────

# Email provider: smtp | sendgrid | mailgun | postmark
EMAIL_PROVIDER=smtp

# SMTP settings (for local development, use Mailhog — auto-configured)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=noreply@adnexus.local
SMTP_FROM_NAME=AdNexus

# SendGrid API key (uncomment if using SendGrid)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# 📁 FILE STORAGE (S3 / MinIO)
# ─────────────────────────────────────────────────────────────────────────────

# Storage provider: local | s3 | minio
STORAGE_PROVIDER=local

# Local storage path (relative to project root)
STORAGE_LOCAL_PATH=./uploads

# S3/MinIO configuration
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=adnexus-uploads
S3_FORCE_PATH_STYLE=true              # Required for MinIO
S3_PUBLIC_URL=http://localhost:9000   # Public URL for file access

# Max upload size (10MB)
MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# ─────────────────────────────────────────────────────────────────────────────
# 📊 MONITORING & OBSERVABILITY
# ─────────────────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error | silent
LOG_LEVEL=debug

# Log format: json | pretty
LOG_FORMAT=pretty

# Enable request logging
LOG_REQUESTS=true

# Prometheus metrics enabled
METRICS_ENABLED=true
METRICS_PORT=9090

# OpenTelemetry / Jaeger tracing
OTEL_ENABLED=false
OTEL_SERVICE_NAME=adnexus-backend
OTEL_EXPORTER_JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# ─────────────────────────────────────────────────────────────────────────────
# 🛡️ EXTERNAL API KEYS
# ─────────────────────────────────────────────────────────────────────────────

# Google OAuth 2.0 (for Google login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Meta / Facebook (for ad platform integrations)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_CUSTOMER_ID=your-customer-id
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-login-customer-id

# Apple Search Ads
APPLE_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nyour-private-key\n-----END EC PRIVATE KEY-----
APPLE_KEY_ID=your-key-id
APPLE_ISSUER_ID=your-issuer-id
APPLE_TEAM_ID=your-team-id

# ─────────────────────────────────────────────────────────────────────────────
# 🤖 AI / ML INTEGRATIONS
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-org-id
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307

# Together AI
TOGETHER_API_KEY=your-together-api-key

# ─────────────────────────────────────────────────────────────────────────────
# 🔄 BACKGROUND JOBS
# ─────────────────────────────────────────────────────────────────────────────

# BullMQ / job queue settings
QUEUE_ENABLED=true
QUEUE_REDIS_DB=1

# Job retention (how long to keep completed/failed jobs)
QUEUE_CLEANUP_HOURS=24

# Max concurrent jobs per worker
QUEUE_CONCURRENCY=5

# ─────────────────────────────────────────────────────────────────────────────
# 🧪 TESTING
# ─────────────────────────────────────────────────────────────────────────────

# Test database (separate from dev database)
TEST_DATABASE_URL=postgresql://adnexus:devpassword123@postgres:5432/adnexus_test?schema=public

# E2E test settings
E2E_BASE_URL=http://localhost:3001
E2E_TIMEOUT=30000

# Playwright / Puppeteer settings (for browser E2E)
BROWSER_HEADLESS=true
BROWSER_SLOW_MO=0

# ─────────────────────────────────────────────────────────────────────────────
# 🐳 DOCKER / DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────

# Docker registry for production images
DOCKER_REGISTRY=ghcr.io/your-org

# Container resource limits (production)
CONTAINER_MEMORY_LIMIT=512M
CONTAINER_CPU_LIMIT=1.0

# Health check configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s

# ─────────────────────────────────────────────────────────────────────────────
# 🧩 OPTIONAL SERVICES (enabled via docker compose profiles)
# ─────────────────────────────────────────────────────────────────────────────

# Mailhog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# 📋 DEVELOPMENT HELPERS
# ─────────────────────────────────────────────────────────────────────────────

# Enable Prisma query logging in development
PRISMA_LOG_QUERIES=true

# Enable debug mode for various packages
DEBUG=adnexus:*

# Nodemon polling (required for Docker bind mounts on macOS/Windows)
CHOKIDAR_USEPOLLING=true
CHOKIDAR_INTERVAL=1000

# ─────────────────────────────────────────────────────────────────────────────
# 🚀 FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────

# Enable beta features
FEATURE_AI_ANALYSIS=true
FEATURE_ADVANCED_REPORTING=false
FEATURE_MULTI_TENANT=false
FEATURE_WEBHOOKS=true

# ─────────────────────────────────────────────────────────────────────────────
