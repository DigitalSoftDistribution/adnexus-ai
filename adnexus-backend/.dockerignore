# =============================================================================
# Docker Ignore — AdNexus Backend
# =============================================================================
# Prevents unnecessary files from being sent to the Docker build context,
# resulting in faster builds and smaller images.
# =============================================================================

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build output
dist
build
*.tsbuildinfo

# Python
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.venv
venv

# Git
.git
.gitattributes
.gitignore

# Environment files (contain secrets — never copy into images)
.env
.env.*
!.env.example

# Documentation
*.md
docs/

# Docker (prevent recursive copies)
Dockerfile*
docker-compose*.yml
.dockerignore

# Testing
coverage
.nyc_output
*.lcov

# IDE / Editor files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Temporary files
tmp
temp
*.tmp
