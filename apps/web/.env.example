# AdNexus AI — Web (Next.js 15 App Router)
#
# Copy to apps/web/.env.local for local development.
# The browser talks to the API through Next.js rewrites — no NEXT_PUBLIC_API_URL
# is required unless you add client-side direct fetches (we proxy instead).

# ── Server-side API proxy ─────────────────────────────────────────────────────
# Used by next.config.ts rewrites (/api/v1/* and /api/v2/* → backend) and by
# server route handlers (e.g. app/api/contact/route.ts).
# Defaults to http://localhost:3001 when unset.
API_URL=http://localhost:3001

# Optional override for the marketing contact form handler only.
# Falls back to API_URL when unset.
# ADNEXUS_API_URL=

# ── Runtime ───────────────────────────────────────────────────────────────────
# Next.js sets NODE_ENV automatically (development | production | test).
# Do not commit real secrets here — backend keys live in apps/api/.env.
