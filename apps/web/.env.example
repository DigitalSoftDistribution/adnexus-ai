# AdNexus AI — Web (Next.js) environment variables
#
# The web app proxies /api/v1/* and /api/v2/* to the backend API via
# Next.js rewrites (see next.config.ts), so the browser never needs a
# public API URL.

# Base URL of the AdNexus API (Express backend). Used by Next.js rewrites
# and server-side route handlers. Defaults to http://localhost:3001 in dev.
API_URL=http://localhost:3001

# Optional override used by the contact form route handler
# (app/api/contact/route.ts). Falls back to API_URL when unset.
# ADNEXUS_API_URL=
