# ─── Core ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ─── Supabase / Database ────────────────────────────────────
SUPABASE_URL=https://example.supabase.co
# Service-role key (server-only). Code reads SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-local-anon-key
# Postgres connection string used by the pg pool / migrations.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/adnexus
# Optional alternate name some tooling reads:
SUPABASE_DB_URL=

# ─── Auth, crypto & secrets ─────────────────────────────────
JWT_SECRET=replace-with-at-least-32-characters
# REQUIRED in production. 64 hex chars (32 bytes). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=
# Optional; falls back to ENCRYPTION_MASTER_KEY when unset.
HMAC_SECRET=
# Bearer token guarding /health detailed checks.
HEALTH_CHECK_TOKEN=

# ─── URLs / CORS ────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Redis (workers / rate limiting) ────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost

# ─── Billing (Stripe) ───────────────────────────────────────
# Without these, billing endpoints respond "not configured" (see KNOWN_LIMITATIONS).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs per plan tier (as configured in Stripe):
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ─── AI providers ───────────────────────────────────────────
# At least one is required for AI features (gpt-4o primary, Anthropic fallback).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Email (SendGrid or SMTP; dev falls back to JSON transport) ─
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=AdNexus AI
# Legacy aliases also read by the mailer:
FROM_EMAIL=
FROM_NAME=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Meta (Marketing API) ───────────────────────────────────
META_APP_ID=mock-meta-app-id
META_APP_SECRET=mock-meta-app-secret
META_API_VERSION=v23.0
META_REDIRECT_URI=http://localhost:3001/api/v1/auth/meta/callback
META_WEBHOOK_VERIFY_TOKEN=
META_RATE_LIMIT_PER_HOUR=200
# Dev/test-only fallback token (ignored in staging/production):
META_ACCESS_TOKEN=
# Local wiremock base (dev only):
META_GRAPH_URL=http://localhost:9085

# ─── Google Ads ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=mock-google-client-id
GOOGLE_CLIENT_SECRET=mock-google-client-secret
# Code reads GOOGLE_DEVELOPER_TOKEN:
GOOGLE_DEVELOPER_TOKEN=mock-google-dev-token
GOOGLE_ADS_API_VERSION=v21
GOOGLE_CUSTOMER_ID=
GOOGLE_LOGIN_CUSTOMER_ID=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback
GOOGLE_WEBHOOK_SECRET=
# Local wiremock bases (dev only):
GOOGLE_ADS_API_URL=http://localhost:9085/v16
GOOGLE_OAUTH_URL=http://localhost:9085/google/oauth2/auth
GOOGLE_TOKEN_URL=http://localhost:9085/token
GOOGLE_TOKEN_INFO_URL=http://localhost:9085/tokeninfo

# ─── TikTok (mock-only unless ENABLE_MOCK_SOCIAL_SYNC) ───────
TIKTOK_APP_ID=mock-tiktok-app-id
TIKTOK_APP_SECRET=mock-tiktok-app-secret
TIKTOK_WEBHOOK_SECRET=
TIKTOK_API_URL=http://localhost:9085/open_api/v1.3

# ─── Snapchat (mock-only unless ENABLE_MOCK_SOCIAL_SYNC) ─────
SNAP_CLIENT_ID=mock-snap-client-id
SNAP_CLIENT_SECRET=mock-snap-client-secret
SNAP_APP_SECRET=mock-snap-app-secret
SNAP_API_BASE_URL=http://localhost:9085/v1
SNAP_OAUTH_BASE_URL=http://localhost:9085/snap/oauth2

# Enable deterministic mock TikTok/Snap sync fixtures:
ENABLE_MOCK_SOCIAL_SYNC=false

# ─── Observability (optional) ───────────────────────────────
SENTRY_DSN=
GRAFANA_URL=
RUNBOOK_URL=

# ─── Mock traffic harness (preview/dev only) ────────────────
# Preview-only DB data seeding must remain disabled unless explicitly gated by
# the backend harness endpoint and a private key. WireMock admin is local/internal only.
MOCK_TRAFFIC_HARNESS_ENABLED=false
MOCK_TRAFFIC_HARNESS_CONTEXT=
MOCK_TRAFFIC_HARNESS_KEY=
# Seed endpoint auth: header x-mock-traffic-key (alias: x-mock-traffic-harness-key) or body.harnessKey
