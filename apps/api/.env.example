NODE_ENV=development
PORT=3001
LOG_LEVEL=info

SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_KEY=replace-with-local-service-key
SUPABASE_ANON_KEY=replace-with-local-anon-key
JWT_SECRET=replace-with-at-least-32-characters
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

META_APP_ID=mock-meta-app-id
META_APP_SECRET=mock-meta-app-secret
META_API_VERSION=v19.0
META_GRAPH_URL=http://localhost:9085

GOOGLE_CLIENT_ID=mock-google-client-id
GOOGLE_CLIENT_SECRET=mock-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=mock-google-dev-token
GOOGLE_ADS_API_URL=http://localhost:9085/v16
GOOGLE_OAUTH_URL=http://localhost:9085/google/oauth2/auth
GOOGLE_TOKEN_URL=http://localhost:9085/token
GOOGLE_TOKEN_INFO_URL=http://localhost:9085/tokeninfo

TIKTOK_APP_ID=mock-tiktok-app-id
TIKTOK_APP_SECRET=mock-tiktok-app-secret
TIKTOK_API_URL=http://localhost:9085/open_api/v1.3

SNAP_CLIENT_ID=mock-snap-client-id
SNAP_CLIENT_SECRET=mock-snap-client-secret
SNAP_API_BASE_URL=http://localhost:9085/v1
SNAP_OAUTH_BASE_URL=http://localhost:9085/snap/oauth2

# Preview-only DB data seeding must remain disabled unless explicitly gated by
# the backend harness endpoint and a private key. WireMock admin is local/internal only.
MOCK_TRAFFIC_HARNESS_ENABLED=false
MOCK_TRAFFIC_HARNESS_CONTEXT=
MOCK_TRAFFIC_HARNESS_KEY=
