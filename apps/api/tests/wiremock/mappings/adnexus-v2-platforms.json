          "Content-Type": {
            "contains": "application/x-www-form-urlencoded"
          }
        },
        "bodyPatterns": [
          {
            "contains": "grant_type=refresh_token"
          }
        ]
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "jsonBody": {
          "access_token": "ya29.MockRefreshedAccessToken_Refresh",
